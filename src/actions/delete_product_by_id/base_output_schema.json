{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": { "title": "Produkt-ID", "type": "integer" },
    "name": { "title": "Produktnamn", "type": "string" },
    "slug": { "title": "URL-slug", "type": "string" },
    "permalink": { "title": "Permanent länk", "type": "string" },
    "type": { "title": "Produkttyp", "type": "string" },
    "status": { "title": "Status", "type": "string" },
    "featured": { "title": "Framhävd produkt", "type": "boolean" },
    "catalog_visibility": { "title": "Synlighet i katalog", "type": "string" },
    "description": { "title": "Beskrivning", "type": "string" },
    "short_description": { "title": "Kort beskrivning", "type": "string" },
    "sku": { "title": "Artikelnummer (SKU)", "type": "string" },
    "price": { "title": "Nuvarande pris", "type": "string" },
    "regular_price": { "title": "Ordinarie pris", "type": "string" },
    "sale_price": { "title": "Reapris", "type": "string" },
    "date_on_sale_from": { "title": "Rea startdatum", "type": "string", "format": "date-time" },
    "date_on_sale_to": { "title": "Rea slutdatum", "type": "string", "format": "date-time" },
    "price_html": { "title": "Pris (HTML)", "type": "string" },
    "on_sale": { "title": "Är på rea", "type": "boolean" },
    "purchasable": { "title": "Kan köpas", "type": "boolean" },
    "total_sales": { "title": "Antal sålda", "type": "integer" },
    "virtual": { "title": "Virtuell produkt", "type": "boolean" },
    "downloadable": { "title": "Nedladdningsbar", "type": "boolean" },
    "downloads": {
      "title": "Nedladdningsbara filer",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "title": "Fil-ID", "type": "string" },
          "name": { "title": "Filnamn", "type": "string" },
          "file": { "title": "Fil-URL", "type": "string" }
        }
      }
    },
    "download_limit": { "title": "Nedladdningsgräns", "type": "integer" },
    "download_expiry": { "title": "Nedladdning upphör (dagar)", "type": "integer" },
    "external_url": { "title": "Extern URL", "type": "string" },
    "button_text": { "title": "Knapptext", "type": "string" },
    "tax_status": { "title": "Skattestatus", "type": "string" },
    "tax_class": { "title": "Skatteklass", "type": "string" },
    "manage_stock": { "title": "Hantera lager", "type": "boolean" },
    "stock_quantity": { "title": "Lagersaldo", "type": "integer" },
    "stock_status": { "title": "Lagerstatus", "type": "string" },
    "backorders": { "title": "Restordrar", "type": "string" },
    "backorders_allowed": { "title": "Restordrar tillåtna", "type": "boolean" },
    "backordered": { "title": "Är restorder", "type": "boolean" },
    "sold_individually": { "title": "Säljs styckvis", "type": "boolean" },
    "weight": { "title": "Vikt", "type": "string" },
    "dimensions": {
      "title": "Dimensioner",
      "type": "object",
      "properties": {
        "length": { "title": "Längd", "type": "string" },
        "width": { "title": "Bredd", "type": "string" },
        "height": { "title": "Höjd", "type": "string" }
      }
    },
    "shipping_required": { "title": "Kräver frakt", "type": "boolean" },
    "shipping_taxable": { "title": "Frakt är skattepliktig", "type": "boolean" },
    "shipping_class": { "title": "Fraktklass (slug)", "type": "string" },
    "shipping_class_id": { "title": "Fraktklass-ID", "type": "integer" },
    "reviews_allowed": { "title": "Tillåt recensioner", "type": "boolean" },
    "average_rating": { "title": "Snittbetyg", "type": "string" },
    "rating_count": { "title": "Antal betyg", "type": "integer" },
    "related_ids": { "title": "Relaterade produkter (ID)", "type": "array", "items": { "type": "integer" } },
    "upsell_ids": { "title": "Mersälj (ID)", "type": "array", "items": { "type": "integer" } },
    "cross_sell_ids": { "title": "Korsförsäljning (ID)", "type": "array", "items": { "type": "integer" } },
    "parent_id": { "title": "Förälder-ID", "type": "integer" },
    "purchase_note": { "title": "Köpsnotis", "type": "string" },
    "categories": {
      "title": "Kategorier",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "title": "Kategori-ID", "type": "integer" },
          "name": { "title": "Kategorinamn", "type": "string" },
          "slug": { "title": "Kategori-slug", "type": "string" }
        }
      }
    },
    "tags": {
      "title": "Taggar",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "title": "Tagg-ID", "type": "integer" },
          "name": { "title": "Taggnamn", "type": "string" },
          "slug": { "title": "Tagg-slug", "type": "string" }
        }
      }
    },
    "images": {
      "title": "Bilder",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "title": "Bild-ID", "type": "integer" },
          "src": { "title": "Bild-URL", "type": "string" },
          "name": { "title": "Bildnamn", "type": "string" },
          "alt": { "title": "Alternativ text", "type": "string" }
        }
      }
    },
    "attributes": {
      "title": "Attribut",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "title": "Attribut-ID", "type": "integer" },
          "name": { "title": "Namn", "type": "string" },
          "slug": { "title": "Slug", "type": "string" },
          "option": { "title": "Valt alternativ", "type": "string" }
        }
      }
    },
    "variations": { "title": "Varianter (ID)", "type": "array", "items": { "type": "integer" } },
    "menu_order": { "title": "Menyordning", "type": "integer" },
    "meta_data": {
      "title": "Metadata",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "title": "Meta-ID", "type": "integer" },
          "key": { "title": "Nyckel", "type": "string" },
          "value": { "title": "Värde", "type": "object", "properties": {} }
        }
      }
    }
  }
}
